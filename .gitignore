# ===================
# Drupal Backend
# ===================

# Composer dependencies (install via: composer install)
seller-backend/drupal/vendor/

# Drupal core (installed via composer)
seller-backend/drupal/web/core/

# Contrib modules (installed via composer)
seller-backend/drupal/web/modules/contrib/

# Contrib themes (installed via composer)
seller-backend/drupal/web/themes/contrib/

# Contrib profiles (installed via composer)
seller-backend/drupal/web/profiles/contrib/

# Drupal files directory (user uploads, generated files)
seller-backend/drupal/web/sites/default/files/

# Drupal settings (generated at install, contains DB credentials)
seller-backend/config/settings.php
seller-backend/config/services.yml

# Drupal private files
seller-backend/drupal/private/

# PHP / Composer cache
seller-backend/drupal/web/sites/default/settings.php
seller-backend/drupal/web/sites/default/services.yml

# ===================
# React Frontend
# ===================

# Node dependencies (install via: npm install)
seller-frontend/node_modules/

# Build output (generate via: npm run build)
seller-frontend/dist/

# ===================
# Logs & temp files
# ===================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
