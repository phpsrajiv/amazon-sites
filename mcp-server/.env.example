# SellerBuddy AI Agents — MCP Server environment variables
#
# Option A: single remote base (all agents live under one domain)
# Individual agent paths are appended automatically:
#   /seo, /content, /video-script, /video-generator, /social
#
# SELLERBUDDY_REMOTE_BASE=https://api.sellerbuddy.app

# Option B: one URL per agent (overrides SELLERBUDDY_REMOTE_BASE)
#
# SELLERBUDDY_SEO_URL=https://seo.api.sellerbuddy.app
# SELLERBUDDY_CONTENT_URL=https://content.api.sellerbuddy.app
# SELLERBUDDY_VIDEO_SCRIPT_URL=https://video-script.api.sellerbuddy.app
# SELLERBUDDY_VIDEO_GENERATOR_URL=https://video-generator.api.sellerbuddy.app
# SELLERBUDDY_SOCIAL_URL=https://social.api.sellerbuddy.app

# If neither is set, all agents default to localhost (Docker Compose stack):
#   http://localhost:8001  SEO
#   http://localhost:8002  Content Writer
#   http://localhost:8003  Video Script
#   http://localhost:8004  Video Generator
#   http://localhost:8005  Social Media
